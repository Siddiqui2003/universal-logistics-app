# Copy this file to .env and change the values before deploying

# Port the server listens on
PORT=3000

# Secret used to sign login sessions (JWT). Use a long random string in production.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Where the SQLite database file is stored. Leave unset for local development
# (it defaults to ./data/app.db). When deploying to Railway/Render, point this
# at your mounted persistent volume, e.g. DB_PATH=/data/app.db
# DB_PATH=/data/app.db
